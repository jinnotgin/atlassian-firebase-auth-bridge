PORT=8080

ATLASSIAN_CLIENT_ID=your-atlassian-client-id
ATLASSIAN_CLIENT_SECRET=your-atlassian-client-secret
ATLASSIAN_REDIRECT_URI=https://your-auth-backend.example.com/auth/atlassian/callback

FRONTEND_BASE_URL=https://your-vue-app.example.com
ALLOWED_FRONTEND_ORIGINS=https://your-vue-app.example.com,http://localhost:5173
ALLOWED_CORS_ORIGINS=https://your-vue-app.example.com,http://localhost:5173

LOGIN_CODE_SECRET=generate-a-long-random-secret

GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-service-account.json